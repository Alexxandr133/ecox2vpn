## Copy to .env and fill values

# Telegram bot token (from @BotFather)
BOT_TOKEN=PASTE_BOT_TOKEN_HERE

# Public WebApp URL (must be https for Telegram WebApp)
WEB_APP_URL=https://ecox2vpn.online/

# VLESS connection settings (your Xray VLESS inbound)
VLESS_HOST=ecox2vpn.online
VLESS_PORT=4433
VLESS_TRANSPORT=tcp
VLESS_TLS=none

# Xray integration (optional, for real provisioning)
XRAY_CONFIG_PATH=/usr/local/etc/xray/config.json
XRAY_SYSTEMD_SERVICE=xray

# Admin panel access (HTTP Basic Auth)
# Set these in your server .env (do not commit real password)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=PASTE_STRONG_PASSWORD_HERE

